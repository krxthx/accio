# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: openai-compat | anthropic
LLM_PROVIDER=openai-compat

# OpenAI-compatible (covers Ollama locally, OpenRouter, OpenAI, LM Studio, vLLM)
OPENAI_COMPAT_BASE_URL=http://localhost:11434/v1
OPENAI_COMPAT_API_KEY=ollama
OPENAI_COMPAT_MODEL=gemma3:27b

# Anthropic (prod)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Parallelism ───────────────────────────────────────────────────────────────
# Number of parallel LLM workers. Keep at 1 for local Ollama (GPU serializes anyway).
# Increase for cloud API endpoints (OpenRouter, Anthropic) — up to rate limits.
LLM_PARALLEL_WORKERS=1

# ── Embeddings (for dedup) ────────────────────────────────────────────────────
# Default: in-process ONNX via @huggingface/transformers — no server needed.
# Model downloads once (~22MB) to ~/.cache/huggingface on first run.
# EMBED_MODEL=Xenova/all-MiniLM-L6-v2

# To use Ollama instead, set:
# EMBED_PROVIDER=openai-compat
# EMBED_BASE_URL=http://localhost:11434/v1
# EMBED_API_KEY=ollama
# EMBED_MODEL=nomic-embed-text

# ── Sources ───────────────────────────────────────────────────────────────────
LANGSEARCH_API_KEY=
# LANGSEARCH_ENDPOINT=https://api.langsearch.com/v1/web-search

# ── Output ────────────────────────────────────────────────────────────────────
OUTPUT_DIR=./output
LOG_LEVEL=info
