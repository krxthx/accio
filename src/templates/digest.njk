<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Accio · AI Digest — {{ dateRange }}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:          #080b12;
      --surface:     #0f1320;
      --surface-2:   #151b2e;
      --border:      #1e2538;
      --border-soft: #161d2e;
      --text:        #dde1f0;
      --text-dim:    #8892aa;
      --text-faint:  #4a5268;
      --accent:      #7b70ff;
      --accent-glow: rgba(123,112,255,0.12);
      --green:       #3ecf8e;
      --blue:        #60a5fa;
      --yellow:      #f0b429;
      --red:         #f87171;
      --s5:          #7b70ff;
      --s4:          #3ecf8e;
      --s3:          #60a5fa;
      --s2:          #f0b429;
      --s1:          #f87171;
      --radius:      10px;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: -apple-system, BlinkMacSystemFont, "Inter", "Segoe UI", system-ui, sans-serif;
      font-size: 14.5px;
      line-height: 1.65;
      min-height: 100vh;
    }

    /* ── Layout ─────────────────────────────────────────────────── */
    .layout {
      display: grid;
      grid-template-columns: 220px 1fr;
      grid-template-rows: auto 1fr;
      max-width: 1180px;
      margin: 0 auto;
      min-height: 100vh;
    }

    /* ── Top bar ─────────────────────────────────────────────────── */
    .topbar {
      grid-column: 1 / -1;
      display: flex;
      align-items: center;
      gap: 1.5rem;
      padding: 0 2rem;
      height: 56px;
      border-bottom: 1px solid var(--border);
      background: rgba(8,11,18,0.9);
      backdrop-filter: blur(12px);
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .topbar-logo {
      font-size: 1rem;
      font-weight: 800;
      letter-spacing: -0.03em;
      background: linear-gradient(135deg, #a89cff 0%, #7b70ff 50%, #5b8cff 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .topbar-divider { width: 1px; height: 20px; background: var(--border); }
    .topbar-meta { color: var(--text-dim); font-size: 0.8rem; }
    .topbar-date {
      margin-left: auto;
      color: var(--text-faint);
      font-size: 0.78rem;
      font-variant-numeric: tabular-nums;
    }

    /* ── Sidebar ─────────────────────────────────────────────────── */
    .sidebar {
      grid-column: 1;
      padding: 2rem 1.5rem 2rem 2rem;
      border-right: 1px solid var(--border-soft);
      position: sticky;
      top: 56px;
      height: calc(100vh - 56px);
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }

    .sidebar-section-label {
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--text-faint);
      margin-bottom: 0.6rem;
    }

    .nav-item {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0.45rem 0.6rem;
      border-radius: 6px;
      text-decoration: none;
      color: var(--text-dim);
      font-size: 0.82rem;
      font-weight: 500;
      transition: background 0.12s, color 0.12s;
      margin-bottom: 0.1rem;
    }
    .nav-item:hover { background: var(--surface-2); color: var(--text); }
    .nav-item .nav-icon { font-size: 0.95rem; flex-shrink: 0; }
    .nav-item .nav-count {
      margin-left: auto;
      font-size: 0.7rem;
      background: var(--surface-2);
      color: var(--text-faint);
      padding: 0.05rem 0.4rem;
      border-radius: 10px;
      font-variant-numeric: tabular-nums;
    }

    /* Stats in sidebar */
    .stat-grid { display: flex; flex-direction: column; gap: 0.5rem; }
    .stat-row {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      font-size: 0.8rem;
    }
    .stat-row-label { color: var(--text-dim); }
    .stat-row-value { font-weight: 700; font-variant-numeric: tabular-nums; color: var(--text); }

    .funnel {
      margin-top: 0.75rem;
      display: flex;
      flex-direction: column;
      gap: 3px;
    }
    .funnel-bar-wrap {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.7rem;
      color: var(--text-faint);
    }
    .funnel-bar-outer {
      flex: 1;
      height: 5px;
      background: var(--surface-2);
      border-radius: 3px;
      overflow: hidden;
    }
    .funnel-bar-inner {
      height: 100%;
      border-radius: 3px;
      background: linear-gradient(90deg, var(--accent), #5b8cff);
    }
    .funnel-bar-num {
      min-width: 28px;
      text-align: right;
      font-variant-numeric: tabular-nums;
    }

    /* ── Main content ────────────────────────────────────────────── */
    .main {
      grid-column: 2;
      padding: 2.5rem 2.5rem 4rem;
      max-width: 800px;
    }

    .page-heading {
      margin-bottom: 2.5rem;
    }
    .page-heading h1 {
      font-size: 2rem;
      font-weight: 800;
      letter-spacing: -0.04em;
      line-height: 1.2;
      color: var(--text);
      margin-bottom: 0.4rem;
    }
    .page-heading .subtitle {
      color: var(--text-dim);
      font-size: 0.9rem;
    }

    /* ── Section ─────────────────────────────────────────────────── */
    .section {
      margin-bottom: 3.5rem;
      scroll-margin-top: 72px;
    }
    .section-header {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 1.25rem;
      padding-bottom: 0.75rem;
      border-bottom: 1px solid var(--border);
    }
    .section-icon { font-size: 1.1rem; }
    .section-title {
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text-dim);
    }
    .section-count {
      margin-left: auto;
      font-size: 0.72rem;
      color: var(--text-faint);
      background: var(--surface);
      border: 1px solid var(--border);
      padding: 0.15rem 0.55rem;
      border-radius: 20px;
      font-variant-numeric: tabular-nums;
    }

    /* ── Article card ────────────────────────────────────────────── */
    .article {
      position: relative;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.1rem 1.25rem 1rem 1.4rem;
      margin-bottom: 0.6rem;
      transition: border-color 0.15s, background 0.15s;
      overflow: hidden;
    }
    .article::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 3px;
      border-radius: var(--radius) 0 0 var(--radius);
    }
    .article.s5::before { background: var(--s5); }
    .article.s4::before { background: var(--s4); }
    .article.s3::before { background: var(--s3); }
    .article.s2::before { background: var(--s2); }
    .article.s1::before { background: var(--s1); }

    .article.s5 { background: linear-gradient(135deg, rgba(123,112,255,0.04) 0%, var(--surface) 50%); }

    .article:hover {
      border-color: var(--accent);
      background: var(--surface-2);
    }
    .article.s5:hover { border-color: var(--s5); }
    .article.s4:hover { border-color: var(--s4); }
    .article.s3:hover { border-color: var(--s3); }

    .article-header {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
      margin-bottom: 0.55rem;
    }

    .article-title {
      flex: 1;
      font-size: 0.97rem;
      font-weight: 600;
      line-height: 1.4;
    }
    .article-title a {
      color: var(--text);
      text-decoration: none;
    }
    .article-title a:hover { color: var(--accent); }

    .score-pill {
      flex-shrink: 0;
      display: inline-flex;
      align-items: center;
      gap: 0.25rem;
      font-size: 0.7rem;
      font-weight: 700;
      padding: 0.2rem 0.55rem;
      border-radius: 20px;
      margin-top: 0.1rem;
    }
    .score-pill.s5 { background: rgba(123,112,255,0.15); color: var(--s5); border: 1px solid rgba(123,112,255,0.3); }
    .score-pill.s4 { background: rgba(62,207,142,0.12); color: var(--s4); border: 1px solid rgba(62,207,142,0.25); }
    .score-pill.s3 { background: rgba(96,165,250,0.12); color: var(--s3); border: 1px solid rgba(96,165,250,0.25); }
    .score-pill.s2 { background: rgba(240,180,41,0.1); color: var(--s2); border: 1px solid rgba(240,180,41,0.2); }
    .score-pill.s1 { background: rgba(248,113,113,0.1); color: var(--s1); border: 1px solid rgba(248,113,113,0.2); }

    .article-meta {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      flex-wrap: wrap;
      margin-bottom: 0.65rem;
    }

    .source-chip {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      font-size: 0.72rem;
      font-weight: 500;
      padding: 0.15rem 0.55rem;
      border-radius: 20px;
      background: var(--surface-2);
      border: 1px solid var(--border);
      color: var(--text-dim);
    }
    .source-chip.src-arxiv    { color: #b08ee8; border-color: rgba(176,142,232,0.25); background: rgba(176,142,232,0.07); }
    .source-chip.src-hugging  { color: #f5a623; border-color: rgba(245,166,35,0.25); background: rgba(245,166,35,0.07); }
    .source-chip.src-google   { color: #4285f4; border-color: rgba(66,133,244,0.25); background: rgba(66,133,244,0.07); }
    .source-chip.src-anthropic{ color: #d97059; border-color: rgba(217,112,89,0.25); background: rgba(217,112,89,0.07); }
    .source-chip.src-openai   { color: #10a37f; border-color: rgba(16,163,127,0.25); background: rgba(16,163,127,0.07); }
    .source-chip.src-github   { color: #8b949e; border-color: rgba(139,148,158,0.25); background: rgba(139,148,158,0.07); }
    .source-chip.src-hn       { color: #ff6600; border-color: rgba(255,102,0,0.25); background: rgba(255,102,0,0.07); }
    .source-chip.src-reddit   { color: #ff4500; border-color: rgba(255,69,0,0.25); background: rgba(255,69,0,0.07); }

    .meta-dot { color: var(--text-faint); font-size: 0.65rem; }
    .meta-date { font-size: 0.75rem; color: var(--text-dim); font-variant-numeric: tabular-nums; }
    .meta-unverified {
      font-size: 0.68rem;
      color: var(--text-faint);
      background: rgba(240,180,41,0.08);
      border: 1px solid rgba(240,180,41,0.18);
      padding: 0.1rem 0.4rem;
      border-radius: 4px;
    }

    .article-summary {
      font-size: 0.875rem;
      color: var(--text-dim);
      line-height: 1.65;
    }

    .also-covered {
      margin-top: 0.6rem;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.35rem;
      font-size: 0.72rem;
      color: var(--text-faint);
    }
    .also-covered-label { flex-shrink: 0; }
    .also-chip {
      display: inline-block;
      padding: 0.1rem 0.45rem;
      border-radius: 4px;
      background: var(--surface-2);
      border: 1px solid var(--border);
      color: var(--text-faint);
      text-decoration: none;
      transition: color 0.1s, border-color 0.1s;
      max-width: 200px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .also-chip:hover { color: var(--text-dim); border-color: var(--accent); }

    /* ── Failures ────────────────────────────────────────────────── */
    .failures-section {
      margin-top: 2rem;
      border: 1px solid rgba(248,113,113,0.15);
      border-radius: var(--radius);
      overflow: hidden;
    }
    .failures-header {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0.75rem 1rem;
      background: rgba(248,113,113,0.05);
      border-bottom: 1px solid rgba(248,113,113,0.12);
      font-size: 0.78rem;
      font-weight: 600;
      color: var(--red);
      letter-spacing: 0.05em;
    }
    .failure-item {
      display: flex;
      gap: 1rem;
      padding: 0.6rem 1rem;
      font-size: 0.8rem;
      border-bottom: 1px solid var(--border-soft);
    }
    .failure-item:last-child { border-bottom: none; }
    .failure-source { color: var(--red); font-weight: 500; min-width: 100px; flex-shrink: 0; }
    .failure-error { color: var(--text-faint); }

    /* ── Footer ──────────────────────────────────────────────────── */
    .footer {
      margin-top: 3rem;
      padding: 1.25rem 0 0;
      border-top: 1px solid var(--border-soft);
      font-size: 0.75rem;
      color: var(--text-faint);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    /* ── Scrollbar ───────────────────────────────────────────────── */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

    /* ── Responsive ──────────────────────────────────────────────── */
    @media (max-width: 820px) {
      .layout { grid-template-columns: 1fr; }
      .sidebar { display: none; }
      .main { padding: 1.25rem 1.25rem 3rem; }
      .topbar { padding: 0 1.25rem; }
    }

    @media print {
      .sidebar, .topbar { display: none; }
      body { background: white; color: black; }
      .article { border: 1px solid #ccc; background: white; break-inside: avoid; }
    }
  </style>
</head>
<body>

  <!-- Top bar -->
  <div class="topbar">
    <div class="topbar-logo">✦ Accio</div>
    <div class="topbar-divider"></div>
    <div class="topbar-meta">AI Digest</div>
    <div class="topbar-date">{{ dateRange }}</div>
  </div>

  <div class="layout">

    <!-- Sidebar nav -->
    <aside class="sidebar">

      <div>
        <div class="sidebar-section-label">Sections</div>
        {% for section in digest.sections %}
        <a class="nav-item" href="#{{ section.cssClass }}">
          <span class="nav-icon">{{ section.heading | sectionIcon }}</span>
          <span>{{ section.heading | sectionLabel }}</span>
          <span class="nav-count">{{ section.articles | length }}</span>
        </a>
        {% endfor %}
      </div>

      <div>
        <div class="sidebar-section-label">Pipeline</div>
        <div class="stat-grid">
          <div class="stat-row">
            <span class="stat-row-label">Collected</span>
            <span class="stat-row-value">{{ digest.stats.collected }}</span>
          </div>
          <div class="stat-row">
            <span class="stat-row-label">After filter</span>
            <span class="stat-row-value">{{ digest.stats.afterEnhance }}</span>
          </div>
          <div class="stat-row">
            <span class="stat-row-label">After dedup</span>
            <span class="stat-row-value">{{ digest.stats.afterDedup }}</span>
          </div>
          <div class="stat-row">
            <span class="stat-row-label">In digest</span>
            <span class="stat-row-value">{{ digest.stats.inDigest }}</span>
          </div>
        </div>
        <div class="funnel">
          <div class="funnel-bar-wrap">
            <div class="funnel-bar-outer"><div class="funnel-bar-inner" style="width:100%"></div></div>
            <span class="funnel-bar-num">{{ digest.stats.collected }}</span>
          </div>
          <div class="funnel-bar-wrap">
            <div class="funnel-bar-outer"><div class="funnel-bar-inner" style="width:{{ (digest.stats.afterEnhance / digest.stats.collected * 100) | round }}%"></div></div>
            <span class="funnel-bar-num">{{ digest.stats.afterEnhance }}</span>
          </div>
          <div class="funnel-bar-wrap">
            <div class="funnel-bar-outer"><div class="funnel-bar-inner" style="width:{{ (digest.stats.afterDedup / digest.stats.collected * 100) | round }}%"></div></div>
            <span class="funnel-bar-num">{{ digest.stats.afterDedup }}</span>
          </div>
          <div class="funnel-bar-wrap">
            <div class="funnel-bar-outer"><div class="funnel-bar-inner" style="width:{{ (digest.stats.inDigest / digest.stats.collected * 100) | round }}%"></div></div>
            <span class="funnel-bar-num">{{ digest.stats.inDigest }}</span>
          </div>
        </div>
      </div>

    </aside>

    <!-- Main -->
    <main class="main">

      <div class="page-heading">
        <h1>AI Digest</h1>
        <div class="subtitle">{{ dateRange }} &nbsp;·&nbsp; {{ digest.stats.inDigest }} stories across {{ digest.sections | length }} sections</div>
      </div>

      {% for section in digest.sections %}
      <section class="section" id="{{ section.cssClass }}">
        <div class="section-header">
          <span class="section-icon">{{ section.heading | sectionIcon }}</span>
          <span class="section-title">{{ section.heading | sectionLabel }}</span>
          <span class="section-count">{{ section.articles | length }}</span>
        </div>

        {% for article in section.articles %}
        {% set score = article.importanceScore or 3 %}
        <div class="article s{{ score }}">
          <div class="article-header">
            <div class="article-title">
              <a href="{{ article.url }}" target="_blank" rel="noopener">
                {{ article.cleanedTitle or article.title }}
              </a>
            </div>
            {% if article.importanceScore %}
            <div class="score-pill s{{ article.importanceScore }}">★ {{ article.importanceScore }}</div>
            {% endif %}
          </div>

          <div class="article-meta">
            {% set srcKey = article.sourceKey %}
            {% if "arxiv" in srcKey %}
              <span class="source-chip src-arxiv">arxiv</span>
            {% elif srcKey == "hf_blog" %}
              <span class="source-chip src-hugging">hugging face</span>
            {% elif "google" in srcKey or "deepmind" in srcKey %}
              <span class="source-chip src-google">{{ article.sourceName }}</span>
            {% elif "anthropic" in srcKey %}
              <span class="source-chip src-anthropic">{{ article.sourceName }}</span>
            {% elif srcKey == "openai_news" %}
              <span class="source-chip src-openai">{{ article.sourceName }}</span>
            {% elif srcKey == "github" %}
              <span class="source-chip src-github">GitHub</span>
            {% elif srcKey == "hackernews" %}
              <span class="source-chip src-hn">Hacker News</span>
            {% elif "reddit" in srcKey %}
              <span class="source-chip src-reddit">{{ article.sourceName }}</span>
            {% else %}
              <span class="source-chip">{{ article.sourceName }}</span>
            {% endif %}

            {% if article.timestamp and article.timestampVerified %}
            <span class="meta-dot">·</span>
            <span class="meta-date">{{ article.timestamp | formatDate }}</span>
            {% endif %}
            {% if not article.timestampVerified %}
            <span class="meta-unverified">date unknown</span>
            {% endif %}
          </div>

          {% if article.summary %}
          <div class="article-summary">{{ article.summary }}</div>
          {% elif article.rawSnippet %}
          <div class="article-summary">{{ article.rawSnippet }}</div>
          {% endif %}

          {% if article.alsoСoveredBy and article.alsoСoveredBy.length > 0 %}
          <div class="also-covered">
            <span class="also-covered-label">Also covered:</span>
            {% for url in article.alsoСoveredBy %}
            <a class="also-chip" href="{{ url }}" target="_blank" rel="noopener" title="{{ url }}">{{ url | truncate(40, true, '…') }}</a>
            {% endfor %}
          </div>
          {% endif %}
        </div>
        {% endfor %}

      </section>
      {% endfor %}

      {% if digest.failures and digest.failures.length > 0 %}
      <div class="failures-section">
        <div class="failures-header">⚠ Source Failures ({{ digest.failures | length }})</div>
        {% for f in digest.failures %}
        <div class="failure-item">
          <span class="failure-source">{{ f.sourceName }}</span>
          <span class="failure-error">{{ f.error | truncate(120, true, '…') }}</span>
        </div>
        {% endfor %}
      </div>
      {% endif %}

      <div class="footer">
        <span>Generated by <strong>Accio AI v2</strong></span>
        <span>{{ generatedAt | truncate(19, true, '') }}</span>
      </div>

    </main>
  </div>

</body>
</html>
