<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Accio · AI Digest — {{ dateRange }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:          #09090e;
      --surface:     #101015;
      --surface-2:   #16161e;
      --border:      #1e1e2a;
      --border-soft: #13131a;
      --text:        #e0e0ec;
      --text-dim:    #70708a;
      --text-faint:  #38384e;
      --accent:      #7c6dfa;
      --s5:          #7c6dfa;
      --s4:          #34c984;
      --s3:          #5ba8f5;
      --s2:          #e8a828;
      --s1:          #e06060;
      --radius:      7px;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
      font-size: 13.5px;
      line-height: 1.6;
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    /* ── Layout ───────────────────────────────────────────── */
    .layout {
      display: grid;
      grid-template-columns: 188px 1fr;
      grid-template-rows: auto 1fr;
      max-width: 1080px;
      margin: 0 auto;
      min-height: 100vh;
    }

    /* ── Topbar ───────────────────────────────────────────── */
    .topbar {
      grid-column: 1 / -1;
      display: flex;
      align-items: center;
      gap: 1.1rem;
      padding: 0 2rem;
      height: 48px;
      border-bottom: 1px solid var(--border-soft);
      background: rgba(9,9,14,0.88);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .topbar-logo {
      font-size: 0.82rem;
      font-weight: 600;
      letter-spacing: -0.01em;
    }
    .topbar-logo span {
      color: var(--text);
    }
    .topbar-sep { width: 1px; height: 14px; background: var(--border); }
    .topbar-label { color: var(--text-faint); font-size: 0.72rem; }
    .topbar-date {
      margin-left: auto;
      color: var(--text-faint);
      font-size: 0.7rem;
      font-variant-numeric: tabular-nums;
      letter-spacing: 0.01em;
    }

    /* ── Sidebar ──────────────────────────────────────────── */
    .sidebar {
      grid-column: 1;
      padding: 2.25rem 0.75rem 2.25rem 1.75rem;
      border-right: 1px solid var(--border-soft);
      position: sticky;
      top: 48px;
      height: calc(100vh - 48px);
      overflow-y: auto;
    }

    .sidebar-label {
      font-size: 0.58rem;
      font-weight: 600;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--text-faint);
      margin-bottom: 0.65rem;
    }

    .nav-item {
      display: flex;
      align-items: baseline;
      gap: 0.45rem;
      padding: 0.35rem 0.45rem;
      border-radius: 5px;
      text-decoration: none;
      color: var(--text-faint);
      font-size: 0.74rem;
      font-weight: 400;
      transition: background 0.1s, color 0.1s;
      margin-bottom: 0.04rem;
      line-height: 1.4;
    }
    .nav-item:hover { background: var(--surface-2); color: var(--text-dim); }
    .nav-icon { font-size: 0.75rem; flex-shrink: 0; opacity: 0.55; }
    .nav-label { flex: 1; }
    .nav-count {
      font-size: 0.62rem;
      color: var(--text-faint);
      font-variant-numeric: tabular-nums;
      flex-shrink: 0;
      opacity: 0.7;
    }

    /* ── Main ─────────────────────────────────────────────── */
    .main {
      grid-column: 2;
      padding: 3.25rem 3rem 5rem;
      max-width: 720px;
    }

    /* ── Page heading ─────────────────────────────────────── */
    .page-heading {
      margin-bottom: 3rem;
    }
    .page-heading h1 {
      font-family: 'Space Grotesk', 'Inter', system-ui, sans-serif;
      font-size: 2.1rem;
      font-weight: 700;
      font-style: normal;
      letter-spacing: -0.04em;
      line-height: 1.1;
      color: var(--text);
      margin-bottom: 0.6rem;
    }
    .page-heading .subtitle {
      color: var(--text-faint);
      font-size: 0.75rem;
      letter-spacing: 0.02em;
    }

    /* ── Section ──────────────────────────────────────────── */
    .section {
      margin-bottom: 2.75rem;
      scroll-margin-top: 64px;
    }
    .section-header {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 0.9rem;
      padding-bottom: 0.55rem;
      border-bottom: 1px solid var(--border-soft);
    }
    .section-icon { font-size: 0.8rem; opacity: 0.45; }
    .section-title {
      font-size: 0.6rem;
      font-weight: 600;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--text-faint);
    }
    .section-count {
      margin-left: auto;
      font-size: 0.62rem;
      color: var(--text-faint);
      font-variant-numeric: tabular-nums;
      opacity: 0.6;
    }

    /* ── Article card ─────────────────────────────────────── */
    .article {
      position: relative;
      padding: 0.85rem 1rem 0.8rem 1.1rem;
      margin-bottom: 0.4rem;
      border-radius: var(--radius);
      border: 1px solid var(--border-soft);
      background: var(--surface);
      overflow: hidden;
      transition: border-color 0.15s, background 0.15s;
    }
    .article::before {
      content: '';
      position: absolute;
      left: 0; top: 0; bottom: 0;
      width: 2px;
      border-radius: var(--radius) 0 0 var(--radius);
      opacity: 0.7;
    }
    .article.s5::before { background: var(--s5); }
    .article.s4::before { background: var(--s4); }
    .article.s3::before { background: var(--s3); }
    .article.s2::before { background: var(--s2); }
    .article.s1::before { background: var(--s1); }

    .article:hover { border-color: var(--border); background: var(--surface-2); }
    .article.s5:hover { border-color: rgba(124,109,250,0.22); }
    .article.s4:hover { border-color: rgba(52,201,132,0.18); }
    .article.s3:hover { border-color: rgba(91,168,245,0.18); }

    .article-title {
      font-size: 0.875rem;
      font-weight: 500;
      line-height: 1.45;
      margin-bottom: 0.3rem;
      letter-spacing: -0.01em;
    }
    .article-title a {
      color: var(--text);
      text-decoration: none;
    }
    .article-title a:hover { color: var(--accent); }

    .article-meta {
      display: flex;
      align-items: center;
      gap: 0.35rem;
      margin-bottom: 0.45rem;
    }
    .source-label {
      font-size: 0.65rem;
      font-weight: 500;
      color: var(--text-faint);
      letter-spacing: 0.02em;
    }
    .source-label.src-arxiv     { color: #9070cc; }
    .source-label.src-hugging   { color: #b07a1a; }
    .source-label.src-google    { color: #3a74d4; }
    .source-label.src-anthropic { color: #a85040; }
    .source-label.src-openai    { color: #0c8060; }
    .source-label.src-github    { color: #555c66; }
    .source-label.src-hn        { color: #aa4800; }
    .source-label.src-reddit    { color: #aa3000; }

    .meta-sep { color: var(--text-faint); font-size: 0.55rem; opacity: 0.5; }
    .meta-date { font-size: 0.65rem; color: var(--text-faint); font-variant-numeric: tabular-nums; }

    .article-summary {
      font-size: 0.8rem;
      color: var(--text-dim);
      line-height: 1.62;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    /* ── Failures (collapsed) ─────────────────────────────── */
    .failures {
      margin-top: 2rem;
      font-size: 0.72rem;
      color: var(--text-faint);
    }
    .failures summary {
      cursor: pointer;
      list-style: none;
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      user-select: none;
    }
    .failures summary:hover { color: var(--text-dim); }
    .failures-list {
      margin-top: 0.6rem;
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
      padding-left: 0.5rem;
    }
    .failure-row { display: flex; gap: 0.6rem; }
    .failure-source { color: var(--s1); font-weight: 500; flex-shrink: 0; }
    .failure-error { color: var(--text-faint); }

    /* ── Footer ───────────────────────────────────────────── */
    .footer {
      margin-top: 4rem;
      padding-top: 1.1rem;
      border-top: 1px solid var(--border-soft);
      font-size: 0.68rem;
      color: var(--text-faint);
      display: flex;
      justify-content: space-between;
    }

    /* ── Scrollbar ────────────────────────────────────────── */
    ::-webkit-scrollbar { width: 5px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

    /* ── Responsive ───────────────────────────────────────── */
    @media (max-width: 720px) {
      .layout { grid-template-columns: 1fr; }
      .sidebar { display: none; }
      .main { padding: 1.75rem 1.25rem 3rem; }
      .topbar { padding: 0 1.25rem; }
      .page-heading h1 { font-size: 2rem; }
    }

    @media print {
      .sidebar, .topbar { display: none; }
      body { background: white; color: black; font-size: 12px; }
      .article { border: 1px solid #ddd; background: white; break-inside: avoid; }
      .page-heading h1 { color: black; }
    }
  </style>
</head>
<body>

  <div class="topbar">
    <div class="topbar-logo"><span>✦ Accio</span></div>
    <div class="topbar-sep"></div>
    <div class="topbar-label">AI Digest</div>
    <div class="topbar-date">{{ dateRange }}</div>
  </div>

  <div class="layout">

    <aside class="sidebar">
      <div class="sidebar-label">Sections</div>
      {% for section in digest.sections %}
      <a class="nav-item" href="#{{ section.cssClass }}">
        <span class="nav-icon">{{ section.heading | sectionIcon }}</span>
        <span class="nav-label">{{ section.heading | sectionLabel }}</span>
        <span class="nav-count">{{ section.articles | length }}</span>
      </a>
      {% endfor %}
    </aside>

    <main class="main">

      <div class="page-heading">
        <h1>Accio AI News Digest</h1>
        <div class="subtitle">{{ dateRange }} &nbsp;·&nbsp; {{ digest.stats.inDigest }} stories</div>
      </div>

      {% for section in digest.sections %}
      <section class="section" id="{{ section.cssClass }}">
        <div class="section-header">
          <span class="section-icon">{{ section.heading | sectionIcon }}</span>
          <span class="section-title">{{ section.heading | sectionLabel }}</span>
          <span class="section-count">{{ section.articles | length }}</span>
        </div>

        {% for article in section.articles %}
        {% set score = article.importanceScore or 3 %}
        <div class="article s{{ score }}">

          <div class="article-title">
            <a href="{{ article.url }}" target="_blank" rel="noopener">
              {{ article.cleanedTitle or article.title }}
            </a>
          </div>

          <div class="article-meta">
            {% set srcKey = article.sourceKey %}
            {% if "arxiv" in srcKey %}
              <span class="source-label src-arxiv">arxiv</span>
            {% elif srcKey == "hf_blog" %}
              <span class="source-label src-hugging">Hugging Face</span>
            {% elif "google" in srcKey or "deepmind" in srcKey %}
              <span class="source-label src-google">{{ article.sourceName }}</span>
            {% elif "anthropic" in srcKey %}
              <span class="source-label src-anthropic">Anthropic</span>
            {% elif srcKey == "openai_news" %}
              <span class="source-label src-openai">OpenAI</span>
            {% elif srcKey == "github" %}
              <span class="source-label src-github">GitHub</span>
            {% elif srcKey == "hackernews" %}
              <span class="source-label src-hn">Hacker News</span>
            {% elif "reddit" in srcKey %}
              <span class="source-label src-reddit">{{ article.sourceName }}</span>
            {% else %}
              <span class="source-label">{{ article.sourceName }}</span>
            {% endif %}
            {% if article.timestamp and article.timestampVerified %}
            <span class="meta-sep">·</span>
            <span class="meta-date">{{ article.timestamp | formatDate }}</span>
            {% endif %}
          </div>

          {% if article.summary %}
          <div class="article-summary">{{ article.summary }}</div>
          {% elif article.rawSnippet %}
          <div class="article-summary">{{ article.rawSnippet }}</div>
          {% endif %}

        </div>
        {% endfor %}
      </section>
      {% endfor %}

      {% if digest.failures and digest.failures.length > 0 %}
      <details class="failures">
        <summary>⚠ {{ digest.failures | length }} source failures</summary>
        <div class="failures-list">
          {% for f in digest.failures %}
          <div class="failure-row">
            <span class="failure-source">{{ f.sourceName }}</span>
            <span class="failure-error">{{ f.error | truncate(100, true, '…') }}</span>
          </div>
          {% endfor %}
        </div>
      </details>
      {% endif %}

      <div class="footer">
        <span>Accio AI</span>
        <span>{{ generatedAt | truncate(19, true, '') }}</span>
      </div>

    </main>
  </div>

</body>
</html>
